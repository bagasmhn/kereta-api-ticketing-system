generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  phone       String
  role        Role         @default(PEMBELI)

  transaksi   Transaksi[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
    @@map("user")
}

model JenisKereta {
  id            Int            @id @default(autoincrement())
  nama          String
  deskripsi     String?

  jadwal        Jadwal[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
    @@map("jeniskereta")
}

model Jadwal {
  id                   Int             @id @default(autoincrement())

  asal                 String
  tujuan               String

  tanggalBerangkat     DateTime

  jamBerangkat         String
  jamTiba              String

  harga                Int

  jenisKeretaId        Int
  jenisKereta          JenisKereta     @relation(fields: [jenisKeretaId], references: [id])

  gerbong              Gerbong[]

  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
    @@map("jadwal")
}

model Gerbong {
  id            Int          @id @default(autoincrement())

  nama          String
  kapasitas     Int

  jadwalId      Int
  jadwal        Jadwal       @relation(fields: [jadwalId], references: [id])

  kursi         Kursi[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
    @@map("gerbong")

}

model Kursi {
  id                Int               @id @default(autoincrement())

  nomor             String

  status            StatusKursi       @default(AVAILABLE)

  gerbongId         Int
  gerbong           Gerbong           @relation(fields: [gerbongId], references: [id])

  detailBooking     DetailBooking[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
    @@map("kursi")

}

model Transaksi {
  id                Int               @id @default(autoincrement())

  kodeTransaksi     String            @unique

  userId            Int
  user              User              @relation(fields: [userId], references: [id])

  totalPenumpang    Int

  totalHarga        Int

  status            StatusBooking     @default(PENDING)

  paymentMethod    String?
  paymentRef       String?          @unique


  detailBooking     DetailBooking[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
    @@map("transaksi")
}

model DetailBooking {
  id                Int               @id @default(autoincrement())

  transaksiId       Int
  transaksi         Transaksi         @relation(fields: [transaksiId], references: [id])

  kursiId           Int
  kursi             Kursi             @relation(fields: [kursiId], references: [id])

  namaPenumpang     String
  nik               String

  createdAt         DateTime          @default(now())
    @@map("detailbooking")

}

enum StatusKursi {
  AVAILABLE
  BOOKED
}

enum StatusBooking {
  PENDING
  SUCCESS
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  PEMBELI
  PETUGAS
}